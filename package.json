{
  "name": "gams-playwright",
  "version": "1.0.0",
  "description": "GAMS Web Application - Playwright Test Automation Framework",
  "type": "module",
  "scripts": {
    "test": "playwright test",
    "test:ams": "playwright test --project=ams",
    "test:doctor": "playwright test --project=doctor",
    "test:pharmacist": "playwright test --project=pharmacist",
    "test:approvals": "playwright test tests/approvals/",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "report": "playwright show-report"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0"
  }
}
